{
  "name": "user_retention",
  "version": "1.17.0",
  "private": true,
  "description": "Deletes users that did not log in in the last days.",
  "license": "AGPL-3.0-or-later",
  "author": "Joas Schilling <coding@schilljs.com>",
  "type": "module",
  "scripts": {
    "build": "NODE_ENV=production vite build",
    "dev": "NODE_ENV=development vite build --mode development",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "stylelint": "stylelint css/*.css css/*.scss src/**/*.scss src/**/*.vue",
    "stylelint:fix": "stylelint css/*.css css/*.scss src/**/*.scss src/**/*.vue --fix",
    "test:cypress": "cd cypress && ./runLocal.sh run",
    "test:cypress:open": "cd cypress && ./runLocal.sh open",
    "watch": "NODE_ENV=development vite build --mode development --watch"
  },
  "browserslist": [
    "extends @nextcloud/browserslist-config"
  ],
  "dependencies": {
    "@nextcloud/axios": "^2.6.0",
    "@nextcloud/dialogs": "^7.3.0",
    "@nextcloud/initial-state": "^3.0.0",
    "@nextcloud/l10n": "^3.4.1",
    "@nextcloud/router": "^3.1.0",
    "@nextcloud/vue": "^9.8.0",
    "debounce": "^3.0.0",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@nextcloud/browserslist-config": "^3.1.2",
    "@nextcloud/e2e-test-server": "^0.4.0",
    "@nextcloud/eslint-config": "^9.0.0-rc.9",
    "@nextcloud/stylelint-config": "^3.2.2",
    "@nextcloud/vite-config": "^2.5.2",
    "@nextcloud/webpack-vue-config": "^7.0.2",
    "cypress": "^15.14.2",
    "eslint": "^10.4.0",
    "eslint-plugin-cypress": "^6.4.1",
    "vite": "^7.3.3"
  },
  "engines": {
    "node": "^24.0.0",
    "npm": "^11.3.0"
  }
}
